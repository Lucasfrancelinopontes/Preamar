{
  "name": "preamar-scripts",
  "version": "1.0.0",
  "description": "Scripts de automação para o Sistema Preamar",
  "scripts": {
    "start": "node scripts/start-all.js",
    "stop": "node scripts/stop-all.js",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && npm run dev",
    "frontend": "cd form && npm run dev",
    "setup": "node scripts/setup.js",
    "reset": "node scripts/reset-database.js",
    "logs": "concurrently \"tail -f backend/backend.log\" \"tail -f form/frontend.log\"",
    "status": "node scripts/check-status.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": ["preamar", "pesca", "desembarque"],
  "author": "Sistema Preamar",
  "license": "MIT"
}